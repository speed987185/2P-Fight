;   param=value ; assign values to parameters

config_version=5

[addons]

ss2d/version="3.3.1"

[application]

config/name="2 P"
run/main_scene="res://Scenes/main_menu.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameManagerSingleton="*res://scripts/game_manager.gd"
SceneTransition="*res://scripts/scene_transition.gd"
BgmManager="*res://scenes/bgm_manager.tscn"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_super-wakatime/plugin.cfg", "res://addons/rmsmartshape/plugin.cfg")

